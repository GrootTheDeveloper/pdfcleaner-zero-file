# Environment
NODE_ENV=development

# Web Port
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# API Port & Settings
API_PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
# For local Docker Compose:
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/pdfcleaner?schema=public"

# Redis
# For local Docker Compose:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d
ALLOW_FIRST_USER_ADMIN=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Telemetry/Analytics
TELEMETRY_ENABLED=true

