# Production environment example. Copy to your deployment secret store; do not commit real values.

NODE_ENV=production

# Public web URL and API URL
CORS_ORIGIN=https://your-domain.example
NEXT_PUBLIC_API_URL=https://api.your-domain.example/api/v1

# API
API_PORT=3001
API_PREFIX=/api/v1
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ALLOW_FIRST_USER_ADMIN=false

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=pdfcleaner
DATABASE_URL=postgresql://postgres:replace-with-a-strong-password@postgres:5432/pdfcleaner?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Telemetry
TELEMETRY_ENABLED=true
